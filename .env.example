# ═══════════════════════════════════════════════════════════════
# Molty Royale AI Bot — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Single Agent Mode ────────────────────────────────────────
# Your Molty Royale API key (REQUIRED)
MR_API_KEY=mr_live_your_key_here

# ─── Multi-Agent Mode (up to 5 agents per IP) ────────────────
# Comma-separated API keys. If set, MR_API_KEY is ignored.
# MR_API_KEYS=mr_live_key1,mr_live_key2,mr_live_key3,mr_live_key4,mr_live_key5

# Room type: "free" or "paid" (default: free)
MR_ROOM_TYPE=free

# ─── Dashboard ────────────────────────────────────────────────
# Web dashboard port (default: 8080, Railway uses PORT env var)
# DASHBOARD_PORT=8080

# Dashboard password (optional — if set, requires login to view dashboard)
# DASHBOARD_PASSWORD=your_secret_password
